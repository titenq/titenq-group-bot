{
  "name": "titenq-group-bot",
  "version": "1.0.0",
  "description": "Telegram group management bot with member-vote moderation to ban scammers pending admin approval, media handling, GitHub Gist sharing, FAQ and i18n support.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "npm run generate:helpers && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "npm run generate:helpers && tsx --watch src/index.ts",
    "format": "npm run lint:fix && prettier --write .",
    "lint": "npm run format && oxlint && npm run type-check",
    "lint:fix": "oxlint --fix -c oxlintrc.json",
    "type-check": "tsc --noEmit",
    "generate:helpers": "tsx scripts/generate-helpers-index.ts"
  },
  "keywords": [
    "telegram",
    "bot",
    "telegraf",
    "moderation",
    "voting",
    "faq",
    "gist",
    "media",
    "i18n",
    "typescript",
    "sqlite"
  ],
  "author": "TitenQ <titenq@gmail.com> (https://github.com/titenq)",
  "homepage": "https://github.com/titenq/titenq-group-bot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/titenq/titenq-group-bot.git"
  },
  "bugs": {
    "url": "https://github.com/titenq/titenq-group-bot/issues"
  },
  "license": "GPL-3.0",
  "dependencies": {
    "i18next": "^25.8.14",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@prettier/plugin-oxc": "^0.1.3",
    "@types/node": "^25.3.3",
    "oxlint": "^1.51.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
